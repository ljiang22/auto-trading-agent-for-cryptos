{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "check-types": {
            "dependsOn": ["build"]
        },
        "@sentiedge/agent#check-types": {
            "dependsOn": [
                "@elizaos/plugin-solana#build",
                "@elizaos/plugin-direct#build"
            ]
        },
        "build": {
            "outputs": ["dist/**"],
            "dependsOn": ["^@elizaos/core#build"]
        },
        "@sentiedge/agent#build": {
            "outputs": ["dist/**"],
            "dependsOn": [
                "^build",
                "@elizaos/core#build",
                "@elizaos/client-direct#build",
                "@elizaos-plugins/adapter-mongodb#build",
                "@elizaos-plugins/adapter-sqlite#build",
                "@elizaos-plugins/plugin-coinmarketcap#build",
                "@elizaos-plugins/plugin-news#build",
                "@elizaos-plugins/plugin-web-search#build",
                "@elizaos-plugins/plugin-charts#build",
                "@elizaos-plugins/plugin-sentiscore-analysis#build",
                "@elizaos-plugins/plugin-crypto_technic_analysis#build",
                "@elizaos-plugins/plugin-crypto-research-search#build",
                "@elizaos-plugins/plugin-on_chain_data#build",
                "@elizaos-plugins/plugin-prediction#build",
                "@elizaos-plugins/plugin-fearandgreedindex_analysis#build",
                "@elizaos-plugins/plugin-institutional-adoption#build",
                "@elizaos-plugins/plugin-launchpad#build",
                "@elizaos-plugins/plugin-mantle-dex#build"
            ]
        },
        "@elizaos/client-direct#build": {
            "outputs": ["dist/**"],
            "dependsOn": []
        },
        "eliza-docs#build": {
            "outputs": ["build/**"]
        },
        "dev": {
            "persistent": true,
            "cache": true
        }
    }
}
