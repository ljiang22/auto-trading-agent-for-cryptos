{
  "name": "@elizaos-plugins/plugin-cex",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "@elizaos/source": "./src/index.ts",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./nl": {
      "import": {
        "@elizaos/source": "./src/nl/orderNl.ts",
        "types": "./dist/nl/orderNl.d.ts",
        "default": "./dist/nl/orderNl.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --format esm --dts",
    "dev": "tsup --format esm --dts --watch",
    "clean": "rimraf dist",
    "lint": "biome check src/",
    "format": "biome format src/",
    "test:unit": "vitest run __tests__/*.test.ts",
    "test:integration": "node ../../tests/questions/run_plugin_cex_binance_suite.mjs"
  },
  "dependencies": {
    "@binance/common": "^2.3.10",
    "@binance/spot": "^28.0.4",
    "@binance/wallet": "^17.0.5",
    "@elizaos/core": "workspace:^",
    "@elizaos-plugins/plugin-sentiscore-analysis": "workspace:*",
    "@tavily/core": "^0.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "crypto": "^1.0.1",
    "jsonwebtoken": "^9.0.2",
    "ws": "^8.20.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "tsup": "8.3.5"
  },
  "peerDependencies": {
    "whatwg-url": "7.1.0"
  },
  "agentConfig": {
    "pluginType": "elizaos:client:1.0.0"
  }
}
