# Example configuration for multiple API keys
# This shows how to configure multiple API keys for automatic rotation
#
# Google / Gemini: this project uses Vertex AI only. Configure:
#   GOOGLE_VERTEX_PROJECT, GOOGLE_VERTEX_LOCATION, GOOGLE_APPLICATION_CREDENTIALS_JSON
# in your real .env (see .env.example). Key rotation does not apply to Vertex JSON.

# Primary OpenAI API key
OPENAI_API_KEY=your_primary_openai_api_key_here

# Additional OpenAI API keys for rotation
OPENAI_API_KEY_1=your_second_openai_api_key_here
OPENAI_API_KEY_2=your_third_openai_api_key_here

# Primary Anthropic API key
ANTHROPIC_API_KEY=your_primary_anthropic_api_key_here

# Additional Anthropic API keys for rotation
ANTHROPIC_API_KEY_1=your_second_anthropic_api_key_here
ANTHROPIC_API_KEY_2=your_third_anthropic_api_key_here

# The system will automatically:
# 1. Use the primary key first (e.g. OPENAI_API_KEY)
# 2. If that fails with rate limits/auth errors, rotate to OPENAI_API_KEY_1
# 3. Continue rotating through available keys
# 4. Remember failed keys and avoid them for 5 minutes
# 5. Reset failed key tracking after timeout period
# 6. Only fall back to different providers after all keys for current provider fail
