{
  "name": "eliza",
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --apply .",
    "preinstall": "npx only-allow pnpm",
    "build": "turbo run build --filter=!eliza-docs",
    "build-docker": "turbo run build --filter=!eliza-docs --concurrency=4",
    "cleanstart": "if [ -f agent/data/db.sqlite ]; then rm agent/data/db.sqlite; fi && pnpm --filter \"@elizaos/agent\" start --isRoot",
    "cleanstart:debug": "if [ -f agent/data/db.sqlite ]; then rm agent/data/db.sqlite; fi && cross-env NODE_ENV=development VERBOSE=true DEFAULT_LOG_LEVEL=debug DEBUG=eliza:* pnpm --filter \"@elizaos/agent\" start --isRoot",
    "start": "pnpm --filter \"@sentiedge/agent\" start --isRoot",
    "start:client": "pnpm --dir client dev",
    "start:debug": "cross-env NODE_ENV=development VERBOSE=true DEFAULT_LOG_LEVEL=debug DEBUG=eliza:* pnpm --filter \"@elizaos/agent\" start --isRoot",
    "dev": "bash ./scripts/dev.sh",
    "release": "pnpm build && pnpm format && npx lerna publish --no-private --force-publish",
    "clean": "bash ./scripts/clean.sh",
    "docker:build": "docker build --platform linux/amd64 -t sentiedge-agent:latest .",
    "docker:run": "docker run --rm --platform linux/amd64 -p 3000:3000 --env-file .env -e NODE_ENV=production -e SERVER_PORT=3000 sentiedge-agent:latest",
    "docker": "pnpm docker:build && pnpm docker:run",
    "test": "bash ./scripts/test.sh",
    "test:ci-gates": "pnpm --filter @elizaos-plugins/plugin-cex exec vitest run __tests__/adk.intentClassification.test.ts __tests__/idempotency/preSubmitDedup.test.ts __tests__/safety/dependencyHealth.test.ts __tests__/safety/unknownState.test.ts __tests__/risk/auditPersistence.test.ts __tests__/risk/maxOrderSizeRegression.test.ts __tests__/audit/completeness.test.ts __tests__/observability/venueCallLog.test.ts __tests__/observability/secretsLeak.test.ts && pnpm --filter @elizaos/core exec vitest run __tests__/utils/promptInjectionDefense.test.ts __tests__/utils/userFacingError.test.ts __tests__/cexWorkflowApprovalStep.test.ts __tests__/cexDedupApproval.test.ts && node scripts/qa/lint-error-contracts.mjs && vitest run --config vitest.config.qa.ts && vitest run --config vitest.config.agent-harness.ts",
    "test:error-contracts": "node scripts/qa/lint-error-contracts.mjs",
    "test:rag": "node ./scripts/test-rag.mjs",
    "test:rag:20": "node ./scripts/test-rag-20.mjs",
    "test:agent-suite": "node --env-file=.env tests/agent-harness/cli/run-suite.mjs",
    "test:agent-harness": "vitest run --config vitest.config.agent-harness.ts",
    "test:trading-prod": "node --env-file=.env tests/agent-harness/cli/run-trading-prod.mjs",
    "test:trading-prod:generate": "node --env-file=.env scripts/qa/generate-trading-prod-suite.mjs",
    "test:trading-prod:analyze": "node --env-file=.env scripts/qa/analyze-trading-suite.mjs",
    "test:streaming": "bash ./tests/run-streaming-tests.sh",
    "test:streaming:benchmark": "cd tests && node streaming-benchmark.js",
    "test:streaming:manual": "cd tests && node streaming-manual-test.js",
    "migrate:sqlite-to-mongodb": "node ./scripts/migrate-sqlite-to-mongodb.mjs",
    "migrate:paper-orders": "node ./scripts/migrate-paper-orders.mjs",
    "migrate:cleanup-pending-orders": "node ./scripts/migrate-cleanup-pending-orders.mjs",
    "smokeTests": "bash ./scripts/smokeTests.sh",
    "integrationTests": "bash ./scripts/integrationTests.sh",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop senti-agent",
    "pm2:restart": "pm2 restart senti-agent",
    "pm2:delete": "pm2 delete senti-agent",
    "pm2:logs": "pm2 logs senti-agent",
    "pm2:status": "pm2 status",
    "stats:daily": "node scripts/daily-stats.mjs",
    "eval:classifier": "node scripts/eval-classifier.mjs",
    "eval:classifier-static": "node scripts/eval-classifier-static.mjs",
    "sim": "node --env-file-if-exists=.env scripts/agent-sim/runAll.mjs",
    "sim:selftest": "node --test scripts/agent-sim/*.test.mjs",
    "optimize": "node --env-file-if-exists=.env scripts/agent-sim/optimize.mjs",
    "evolve": "node --env-file-if-exists=.env scripts/agent-sim/evolve.mjs",
    "optimize:auto": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/agent-optimizer/autoOptimize.mjs",
    "optimize:auto:selftest": "node --test scripts/agent-optimizer/*.test.mjs",
    "optimize:cycle:plan": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/agent-optimizer/autoOptimize.mjs --plan-only --target-score 90",
    "optimize:cycle:verify": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/agent-optimizer/autoOptimize.mjs --verify --target-score 90",
    "dev:auth": "node --env-file-if-exists=.env scripts/dev-auth.mjs",
    "smoke:sentiscore-s3": "pnpm --filter @elizaos-plugins/plugin-sentiscore-analysis build && node --env-file=.env scripts/smoke-sentiscore-s3.mjs",
    "aws:monitor": "node --env-file=.env scripts/aws-monitor.mjs",
    "aws:monitor:errors": "node --env-file=.env scripts/aws-monitor.mjs --errors-only",
    "aws:monitor:production": "node --env-file=.env scripts/aws-monitor.mjs --agent-service sentiedge-agent",
    "aws:monitor:production:errors": "node --env-file=.env scripts/aws-monitor.mjs --agent-service sentiedge-agent --errors-only",
    "aws:monitor:staging": "node --env-file=.env scripts/aws-monitor.mjs --agent-service sentiedge-agent-staging",
    "aws:monitor:staging:errors": "node --env-file=.env scripts/aws-monitor.mjs --agent-service sentiedge-agent-staging --errors-only"
  },
  "devDependencies": {
    "@binance/common": "^2.3.10",
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "18.6.1",
    "@commitlint/config-conventional": "18.6.3",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.14",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "10.0.0",
    "cli": "workspace:*",
    "concurrently": "9.1.0",
    "cors": "2.8.5",
    "cross-env": "7.0.3",
    "express": "^5.2.1",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "lerna": "8.1.5",
    "nodemon": "3.1.7",
    "only-allow": "1.2.1",
    "supertest": "^7.2.2",
    "turbo": "2.4.4",
    "typedoc": "0.26.11",
    "typescript": "5.6.3",
    "viem": "2.21.58",
    "vite": "5.4.12",
    "vitest": "3.0.5"
  },
  "pnpm": {
    "overrides": {
      "onnxruntime-node": "1.20.1",
      "@solana/web3.js@1.95.5": "npm:@solana/web3.js@1.98.0",
      "@solana/web3.js@1.95.8": "npm:@solana/web3.js@1.98.0",
      "@solana/web3.js@2": "npm:@solana/web3.js@2.0.0",
      "viem": "2.21.58",
      "@polkadot/util": "12.6.2",
      "@polkadot/util-crypto": "12.6.2",
      "@polkadot/types-create": "10.13.1",
      "@polkadot/types-codec": "10.13.1",
      "@polkadot/keyring": "12.6.2",
      "@ai-sdk/provider": "1.0.6",
      "@ai-sdk/provider-utils": "2.1.6",
      "cookie": "0.7.0",
      "bs58": "5.0.0",
      "@coral-xyz/anchor": "0.30.1",
      "axios@>=0.8.1 <0.28.0": ">=0.28.0",
      "undici@>=6.0.0 <6.21.1": ">=6.21.1",
      "path-to-regexp@<0.1.12": ">=0.1.12",
      "secp256k1": "5.0.1",
      "@octokit/request-error@>=1.0.0 <5.1.1": ">=5.1.1",
      "dompurify@<3.2.4": ">=3.2.4",
      "@octokit/request@>=1.0.0 <9.2.1": ">=9.2.1",
      "@octokit/plugin-paginate-rest@>=1.0.0 <11.4.1": ">=11.4.1",
      "esbuild@<=0.24.2": ">=0.25.0",
      "zod": "3.25.76"
    }
  },
  "engines": {
    "node": "23.3.0"
  },
  "dependencies": {
    "@0glabs/0g-ts-sdk": "0.2.1",
    "@aws-sdk/client-cloudwatch-logs": "^3.802.0",
    "@aws-sdk/client-s3": "^3.802.0",
    "@coinbase/coinbase-sdk": "0.10.0",
    "@deepgram/sdk": "^3.11.1",
    "@elizaos-plugins/adapter-mongodb": "workspace:*",
    "@elizaos-plugins/adapter-sqlite": "workspace:*",
    "@elizaos-plugins/plugin-charts": "workspace:*",
    "@elizaos-plugins/plugin-coinmarketcap": "workspace:*",
    "@elizaos-plugins/plugin-content-analysis": "workspace:*",
    "@elizaos-plugins/plugin-crypto-research-search": "workspace:*",
    "@elizaos-plugins/plugin-crypto_technic_analysis": "workspace:*",
    "@elizaos-plugins/plugin-fearandgreedindex_analysis": "workspace:*",
    "@elizaos-plugins/plugin-institutional-adoption": "workspace:*",
    "@elizaos-plugins/plugin-launchpad": "workspace:*",
    "@elizaos-plugins/plugin-news": "workspace:*",
    "@elizaos-plugins/plugin-on_chain_data": "workspace:*",
    "@elizaos-plugins/plugin-prediction": "workspace:*",
    "@elizaos-plugins/plugin-sentiscore-analysis": "workspace:*",
    "@elizaos-plugins/plugin-web-search": "workspace:*",
    "@injectivelabs/sdk-ts": "^1.14.33",
    "@vitest/eslint-plugin": "1.0.1",
    "agent-twitter-client": "workspace:*",
    "amqplib": "0.10.5",
    "better-sqlite3": "^11.8.1",
    "bs58": "4.0.0",
    "canvas": "^3.1.0",
    "csv-parse": "5.6.0",
    "csvtojson": "^2.0.10",
    "date-fns": "^4.1.0",
    "langdetect": "^0.2.1",
    "mongodb": "^6.17.0",
    "next": "^15.3.1",
    "ollama-ai-provider": "0.16.1",
    "optional": "0.1.4",
    "pnpm": "9.15.7",
    "sharp": "0.33.5",
    "uuid": "^11.1.0",
    "ws": "8.18.0",
    "zod": "3.25.76"
  },
  "packageManager": "pnpm@9.15.7",
  "workspaces": [
    "packages/*"
  ]
}
