{
    "name": "@sentiedge/agent",
    "version": "3.0.0",
    "main": "src/index.ts",
    "type": "module",
    "scripts": {
        "start": "node --import 'data:text/javascript,import { register } from \"node:module\"; import { pathToFileURL } from \"node:url\"; register(\"ts-node/esm\", pathToFileURL(\"./\"));' dist/index.js",
        "dev": "node --import 'data:text/javascript,import { register } from \"node:module\"; import { pathToFileURL } from \"node:url\"; register(\"ts-node/esm\", pathToFileURL(\"./\"));' src/index.ts",
        "check-types": "tsc --noEmit",
        "test": "jest",
        "build": "tsup"
    },
    "nodemonConfig": {
        "watch": [
            "src",
            "../core/dist"
        ],
        "ext": "ts,json",
        "exec": "node --enable-source-maps --import 'data:text/javascript,import { register } from \"node:module\"; import { pathToFileURL } from \"node:url\"; register(\"ts-node/esm\", pathToFileURL(\"./\"));' src/index.ts"
    },
    "dependencies": {
        "@elizaos/client-direct": "workspace:*",
        "@elizaos/core": "workspace:*",
        "@elizaos-plugins/plugin-cex": "workspace:*",
        "@elizaos-plugins/adapter-mongodb": "workspace:*",
        "@elizaos-plugins/adapter-sqlite": "workspace:*",
        "@elizaos-plugins/plugin-charts": "workspace:*",
        "@elizaos-plugins/plugin-coinmarketcap": "workspace:*",
        "@elizaos-plugins/plugin-crypto-research-search": "workspace:*",
        "@elizaos-plugins/plugin-crypto_technic_analysis": "workspace:*",
        "@elizaos-plugins/plugin-fearandgreedindex_analysis": "workspace:*",
        "@elizaos-plugins/plugin-institutional-adoption": "workspace:*",
        "@elizaos-plugins/plugin-launchpad": "workspace:*",
        "@elizaos-plugins/plugin-news": "workspace:*",
        "@elizaos-plugins/plugin-on_chain_data": "workspace:*",
        "@elizaos-plugins/plugin-prediction": "workspace:*",
        "@elizaos-plugins/plugin-sentiscore-analysis": "workspace:*",
        "@elizaos-plugins/plugin-web-search": "workspace:*",
        "@tavily/core": "^0.0.2",
        "@types/node": "^22.13.5",
        "axios": "^1.8.1",
        "better-sqlite3": "^11.8.1",
        "canvas": "^3.1.0",
        "combined-stream": "^1.0.8",
        "csvtojson": "^2.0.10",
        "follow-redirects": "^1.15.9",
        "form-data": "^4.0.2",
        "node-fetch": "^3.3.2",
        "proxy-from-env": "^1.1.0",
        "sqlite-vec": "^0.1.6",
        "sqlite-vec-darwin-arm64": "^0.1.6",
        "express": "^4.19.2",
        "json5": "2.2.3",
        "ts-node": "^10.9.2",
        "undici": "^7.4.0",
        "yargs": "17.7.2"
    },
    "devDependencies": {
        "@jest/globals": "^29.7.0",
        "@types/express": "4.17.21",
        "@types/jest": "29.5.14",
        "jest": "29.7.0",
        "ts-jest": "^29.2.6",
        "tsup": "^8.0.0"
    }
}
