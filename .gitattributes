# Normalize line endings to LF across the repo so diffs don't churn on
# CRLF/LF flips (e.g. client/src/components/ui/sidebar.tsx). git auto-detects
# binary files via `text=auto`; explicit markers below are belt-and-suspenders.
* text=auto eol=lf

# Binary assets — never apply EOL conversion.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pem  binary
*.pdf  binary
